{
  "autosize": {
    "type": "fit-x",
    "contains": "padding"
  },
  "width": 980,
  "height": {
    "step": 48
  },
  "config": {
    "font": "Helvetica, Arial, sans-serif",
    "view": {
      "stroke": null
    },
    "axis": {
      "domain": false,
      "gridColor": "#d1d5db",
      "gridDash": [
        5,
        5
      ],
      "labelFontSize": 14,
      "titleFontSize": 15,
      "labelFont": "Helvetica, Arial, sans-serif",
      "titleFont": "Helvetica, Arial, sans-serif"
    },
    "text": {
      "fontSize": 13,
      "font": "Helvetica, Arial, sans-serif"
    }
  },
  "transform": [
    {
      "calculate": "datum.AgingBucket === 'Current' ? -1 : toNumber(replace(split(datum.AgingBucket, '-')[0], '+', ''))",
      "as": "AgingBucketSort"
    },
    {
      "calculate": "datum.Balance >= 1000000000 ? replace(format(datum.Balance / 1000000000, '.1f'), '.0', '') + 'b' : datum.Balance >= 1000000 ? replace(format(datum.Balance / 1000000, '.1f'), '.0', '') + 'm' : datum.Balance >= 1000 ? replace(format(datum.Balance / 1000, '.1f'), '.0', '') + 'k' : format(datum.Balance, '.0f')",
      "as": "BalanceLabel"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 8,
        "color": "#4f46e5",
        "fillOpacity": 0.25,
        "stroke": "#4f46e5",
        "strokeOpacity": 1,
        "strokeWidth": 2
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 4,
        "color": "#1f2937"
      },
      "encoding": {
        "text": {
          "field": "BalanceLabel",
          "type": "nominal"
        }
      }
    }
  ],
  "encoding": {
    "x": {
      "field": "Balance",
      "type": "quantitative",
      "title": "Receivable Balance",
      "axis": {
        "grid": true,
        "gridColor": "#d1d5db",
        "labelExpr": "datum.value >= 1000000000 ? replace(format(datum.value / 1000000000, '.1f'), '.0', '') + 'b' : datum.value >= 1000000 ? replace(format(datum.value / 1000000, '.1f'), '.0', '') + 'm' : datum.value >= 1000 ? replace(format(datum.value / 1000, '.1f'), '.0', '') + 'k' : format(datum.value, '.0f')",
        "gridDash": [
          5,
          5
        ]
      }
    },
    "y": {
      "field": "AgingBucket",
      "type": "ordinal",
      "sort": {
        "field": "AgingBucketSort",
        "op": "min",
        "order": "ascending"
      },
      "axis": {
        "titleAngle": 0,
        "titlePadding": 22
      },
      "title": "Bucket"
    },
    "tooltip": [
      {
        "field": "AgingBucket",
        "type": "ordinal",
        "title": "Bucket"
      },
      {
        "field": "Balance",
        "type": "quantitative",
        "title": "Balance",
        "format": "$,.2f"
      }
    ]
  }
}