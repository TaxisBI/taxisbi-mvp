{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChartThemeV2",
  "type": "object",
  "required": ["key", "label", "scope", "ui", "spec"],
  "properties": {
    "key": { "type": "string" },
    "label": { "type": "string" },
    "createdBy": { "type": "string" },
    "displayOrder": { "type": "integer" },
    "extends": { "type": "string" },
    "scope": {
      "type": "string",
      "enum": ["global", "domain", "pack", "dashboard"]
    },
    "appliesTo": {
      "type": "object",
      "properties": {
        "domain": { "type": "array", "items": { "type": "string" } },
        "pack": { "type": "array", "items": { "type": "string" } },
        "chart": { "type": "array", "items": { "type": "string" } },
        "dashboard": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "ui": {
      "type": "object",
      "properties": {
        "pageBackground": { "type": "string" },
        "pageText": { "type": "string" },
        "cardBackground": { "type": "string" },
        "cardShadow": { "type": "string" },
        "buttonBackground": { "type": "string" },
        "buttonText": { "type": "string" },
        "buttonBorder": { "type": "string" },
        "hoverColor": { "type": "string" },
        "fontFamily": { "type": "string" },
        "modalOverlayBackground": { "type": "string" },
        "statusDanger": { "type": "string" },
        "statusSuccess": { "type": "string" },
        "chartBarDefaultColor": { "type": "string" },
        "chartBarHoverColor": { "type": "string" },
        "chartBarDefaultOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "chartBarHoverOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "chartBarDefaultStrokeColor": { "type": "string" },
        "chartBarHoverStrokeColor": { "type": "string" },
        "chartBarDefaultStrokeOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "chartBarHoverStrokeOpacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "chartBarDefaultStrokeWidth": { "type": "number", "minimum": 0 },
        "chartBarHoverStrokeWidth": { "type": "number", "minimum": 0 },
        "colorTokens": {
          "type": "object",
          "properties": {
            "mono": {
              "type": "object",
              "properties": {
                "primary": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "string" },
                    "dark": { "type": "string" }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                },
                "secondary": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "string" },
                    "dark": { "type": "string" }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                },
                "accent": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "string" },
                    "dark": { "type": "string" }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                }
              },
              "additionalProperties": true
            },
            "multi": {
              "type": "object",
              "properties": {
                "categorical": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "array", "items": { "type": "string" } },
                    "dark": { "type": "array", "items": { "type": "string" } }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                },
                "sequential": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "array", "items": { "type": "string" } },
                    "dark": { "type": "array", "items": { "type": "string" } }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                }
              },
              "additionalProperties": true
            },
            "sentiment": {
              "type": "object",
              "properties": {
                "positive": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "string" },
                    "dark": { "type": "string" }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                },
                "neutral": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "string" },
                    "dark": { "type": "string" }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                },
                "negative": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "string" },
                    "dark": { "type": "string" }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                }
              },
              "additionalProperties": true
            },
            "status": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "string" },
                    "dark": { "type": "string" }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                },
                "warning": {
                  "type": "object",
                  "properties": {
                    "light": { "type": "string" },
                    "dark": { "type": "string" }
                  },
                  "required": ["light", "dark"],
                  "additionalProperties": false
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "overlapPalette": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "border": { "type": "string" },
              "background": { "type": "string" }
            },
            "required": ["border", "background"],
            "additionalProperties": false
          }
        },
        "tooltipTheme": { "type": "string", "enum": ["light", "dark"] }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object",
      "description": "Vega-Lite overrides merged on top of base chart spec",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
