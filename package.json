{
  "name": "taxisbi-mvp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "ui"
  ],
  "description": "Express + TypeScript scaffold",
  "main": "dist/server/index.js",
  "scripts": {
    "dev:start": "node scripts/dev-start.js",
    "dev:stop": "node scripts/dev-stop.js",
    "dev": "node scripts/dev-guard.js",
    "dev:raw": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "ui:dev": "npm run -w ui dev",
    "ui:build": "npm run -w ui build",
    "ui:preview": "npm run -w ui preview"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.2",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-vega": "^8.0.0",
    "vega-lite": "^6.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
